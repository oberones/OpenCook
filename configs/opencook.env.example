OPENCOOK_SERVICE_NAME=opencook
OPENCOOK_ENV=development
OPENCOOK_LISTEN_ADDRESS=:4000
OPENCOOK_DEFAULT_ORGANIZATION=
OPENCOOK_READ_TIMEOUT=15s
OPENCOOK_WRITE_TIMEOUT=30s
OPENCOOK_SHUTDOWN_TIMEOUT=10s
OPENCOOK_AUTH_SKEW=15m
OPENCOOK_MAX_AUTH_BODY_BYTES=8388608
OPENCOOK_BOOTSTRAP_MODE=true
OPENCOOK_BOOTSTRAP_REQUESTOR_NAME=
OPENCOOK_BOOTSTRAP_REQUESTOR_TYPE=user
OPENCOOK_BOOTSTRAP_REQUESTOR_ORG=
OPENCOOK_BOOTSTRAP_REQUESTOR_KEY_ID=default
OPENCOOK_BOOTSTRAP_PUBLIC_KEY_PATH=

# External dependencies
OPENCOOK_POSTGRES_DSN=postgres://opencook:opencook@localhost:5432/opencook?sslmode=disable
OPENCOOK_OPENSEARCH_URL=http://localhost:9200
OPENCOOK_BLOB_STORAGE_URL=file:///tmp/opencook-objects
